## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache files
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build results of 64-bit compilation
x64/

# Entity Framework Core artifacts
*.db-shm
*.db-wal

# SQL Server files
*.mdf
*.ldf
*.ndf

# Local Config
appsettings.Development.json
# Note: Keep appsettings.json, but ignore development overrides if they contain secrets.
# Usually better to use Secrets Manager or Environment Variables.

# Publish output
publish/
*.azurepubxml
